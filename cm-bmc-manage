def setup_parser():
    parser = argparse.ArgumentParser(
        description='Manage BMC',
        formatter_class=argparse.RawTextHelpFormatter,
    )

    def_group = parser.add_mutually_exclusive_group(required=True)
    def_group.add_argument(
        '--identify',
        action='store_true',
        help='Turn on the BMC light so the node can be identified',
    )
    def_group.add_argument(
        '--unidentify',
        action='store_true',
        help='Turn off the BMC light so the node can no longer be identified',
    )
    def_group.add_argument(
        '--is-identified',
        action='store_true',
        help='Show the status of the BMC light',
    )
    def_group.add_argument(
        '--event-logs',
        action='store_true',
        help='Show the BMC event logs',
    )
    def_group.add_argument(
        '--clear-event-logs',
        action='store_true',
        help='Clear the BMC event logs',
    )
    def_group.add_argument(
        '--reset',
        action='store_true',
        help='Reset the BMC controller',
    )
    parser.add_argument(
        '--debug',
        action='store_true',
        help='Debug this script',
    )
    parser.add_argument(
        '--fake',
        action='store_true',
        help='Run in fake mode',
    )
    parser.add_argument(
        '--tail',
        action='store',
        default=100,
        type=int,
        help='Last number of events to retrieve',
    )
    return parser


def main():
    parser = setup_parser()
    args = parser.parse_args()

    if args.debug:
        sys.stderr.write('Run: ')
        sys.stderr.write(' '.join(sys.argv))
        sys.stderr.write('\n')

    node = Node()
    if node.valid:
        # TODO: /cm/local/apps/cluster-tools/ext/bin/ucsmanage
        bmc_types = {
            'h100': H100,
            'gh200': GH200,
            'b200': B200,
            'gb200': GB200,
            'gb200sw': GB200,
            'b300': B300,
            'gb300': GB300,
            'gb300sw': GB300,
        }
        if args.fake or os.path.exists('/root/.fake.bmc') or os.path.exists('/root/.fake'):
            bmc = FakeBMC(debug=args.debug)
        elif node.bmc_type in bmc_types:
            bmc = bmc_types[node.bmc_type](debug=args.debug)
        else:
            bmc = BMC(debug=args.debug)

        if args.identify:
            result = bmc.identify(node)
        elif args.unidentify:
            result = bmc.unidentify(node)
        elif args.is_identified:
            result = bmc.is_identified(node)
        elif args.event_logs:
            result = bmc.event_logs(node, args.tail)
        elif args.clear_event_logs:
            result = bmc.clear_event_logs(node, args.tail)
        elif args.reset:
            result = bmc.reset(node)
        else:
            parser.print_help()
            sys.exit(1)
        bmc.save()
    else:
        result = {'success': False, 'information': 'no valid node BMC environment'}

    if args.debug:
        sys.stderr.write(json.dumps(result))
    print(json.dumps(result, indent=2))


if __name__ == '__main__':
    main()
