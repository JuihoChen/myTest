ansible -i ../hosts.ini gb300_rack -m copy -a "
dest=/etc/systemd/system/nvidia-dcgm.service.d/override.conf
content='[Service]\nRuntimeDirectory=nvidia-dcgm-work\nWorkingDirectory=/run/nvidia-dcgm-work\n'
" --forks 18

ansible -i ../hosts.ini gb300_rack -m systemd -a "daemon_reload=yes name=nvidia-dcgm state=restarted" --forks 18

ansible -i ../hosts.ini gb300_rack -m shell -a "systemctl is-active nvidia-dcgm" --forks 18
